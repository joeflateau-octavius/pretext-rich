{
  "name": "pretext-rich",
  "version": "1.0.0",
  "description": "Rich text inline layout engine built on @chenglou/pretext",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "test": "node --import tsx/esm --test 'src/__tests__/**/*.test.ts'",
    "test:render": "playwright test",
    "test:render:headed": "playwright test --headed"
  },
  "keywords": [
    "layout",
    "text",
    "rich-text",
    "inline"
  ],
  "license": "MIT",
  "dependencies": {
    "@chenglou/pretext": "^0.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
